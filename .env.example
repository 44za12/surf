# Debug mode (True/False)
DEBUG=False

# Port to run the API on
PORT=8000

# Authentication settings
# When AUTH_ENABLED=True and API_KEYS is empty, a key is auto-generated
# on first startup and saved here automatically.
AUTH_ENABLED=True
# API_KEYS=

# Search provider: searxng, duckduckgo, brave
SEARCH_PROVIDER=duckduckgo

# SearXNG settings
# SEARXNG_INSTANCE_URL=https://searx.be
# SEARXNG_AUTH_USERNAME=
# SEARXNG_AUTH_PASSWORD=
# SEARXNG_TIMEOUT=10
# SEARXNG_MAX_RESULTS=10

# DuckDuckGo settings
# DUCKDUCKGO_TIMEOUT=10
# DUCKDUCKGO_MAX_RESULTS=10

# Brave Search settings (requires API key from https://brave.com/search/api/)
# BRAVE_API_KEY=
# BRAVE_TIMEOUT=10
# BRAVE_MAX_RESULTS=10